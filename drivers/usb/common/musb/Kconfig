rsource "glue/Kconfig"

config MUSB
	bool "MUSB USB controller driver core"
	help
	  Mentor Graphics MUSB USB controller driver core.
	  Provides hardware abstraction for MUSB HDRC controllers,
	  shared between UDC (device) and UHC (host) modes.

if MUSB

# NOTE: Do NOT manually define MUSB_LOG_LEVEL as an int here.
# The manual "default 0" would always win over the template's choice
# defaults, freezing the level at 0 (LOG_LEVEL_NONE) and stripping all
# MUSB log output at compile time. Let the template below own it.
module = MUSB
module-str = MUSB
source "subsys/logging/Kconfig.template.log_config"

endif # MUSB
