menuconfig INPUT_NS2009
	bool "NSIWAY NS2009 resistive touchscreen controller"
	default y
	depends on DT_HAS_NSIWAY_NS2009_ENABLED
	select I2C
	select INPUT_TOUCH
	help
	  Enable driver for NSIWAY NS2009 4-wire resistive touchscreen
	  controller. This driver uses Z1 pressure detection polling
	  for touch detection without requiring the PENIRQ interrupt pin.

if INPUT_NS2009

config INPUT_NS2009_SAMPLES
	int "Number of ADC samples for median filter"
	default 3
	range 1 7
	help
	  Number of ADC samples to take for each measurement.
	  The median value is used to filter out noise.
	  Set to 1 to disable median filtering.

endif # INPUT_NS2009
