config SPI_SUN8I_V3S
	bool "Allwinner sun8i V3s SPI driver"
	default y
	depends on DT_HAS_ALLWINNER_SUN8I_V3S_SPI_ENABLED
	help
	  Enable Allwinner sun8i V3s SPI driver.

config SPI_SUN8I_V3S_DMA
	bool "Enable DMA-driven transfer support"
	default y
	depends on SPI_SUN8I_V3S
	depends on DMA_SUN8I_V3S
	help
	  Enable DMA for SPI transfers instead of PIO. When enabled, the
	  driver configures DMA channels for TX (MEMORY_TO_PERIPHERAL)
	  and RX (PERIPHERAL_TO_MEMORY) using the SPI0 DRQ port 23.
	  DMA mode eliminates CPU polling/interrupt overhead for large
	  transfers. Falls back to PIO mode for small transfers below
	  the DMA threshold.
