/dts-v1/;

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/display/panel.h>
#include <zephyr/dt-bindings/pinctrl/allwinner,sun8i-v3s-pinctrl.h>
#include <arm/armv7-a.dtsi>
#include <allwinner/sun8i-v3s.dtsi>

/ {
	model = "Sipeed Lichee Zero";
	compatible = "sipeed,lichee-zero", "allwinner,sun8i-v3s";

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram = &ddr0;
		zephyr,entropy = &rng;
		zephyr,display = &mixer0;
	};

	lvgl_pointer {
		compatible = "zephyr,lvgl-pointer-input";
		input = <&ns2009>;
	};

	leds {
		compatible = "gpio-leds";
		green_led: led_0 {
			gpios = <&gpiog 0 GPIO_ACTIVE_LOW>;
			label = "Green LED";
		};
		blue_led: led_1 {
			gpios = <&gpiog 1 GPIO_ACTIVE_LOW>;
			label = "Blue LED";
		};
		red_led: led_2 {
			gpios = <&gpiog 2 GPIO_ACTIVE_LOW>;
			label = "Red LED";
		};
	};
};

&uart0 {
	pinctrl-0 = <&uart0_pins>;
	pinctrl-names = "default";
	status = "okay";
	current-speed = <115200>;
};

&timer0 {
	status = "okay";

	counter0: counter@0 {
		status = "okay";
	};
};

&pinctrl {
	status = "okay";

	default_state {
		i2c0_pins: i2c0-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_B, 6, FUNC_PB_TWI0)>,
				 <SUN8I_V3S_PINMUX(PORT_B, 7, FUNC_PB_TWI0)>;
		};

		pwm_pins: pwm-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_B, 4, FUNC_PB_PWM)>,
				 <SUN8I_V3S_PINMUX(PORT_B, 5, FUNC_PB_PWM)>;
		};

		spi0_pins: spi0-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_C, 0, FUNC_PC_SPI0)>,
				 <SUN8I_V3S_PINMUX(PORT_C, 1, FUNC_PC_SPI0)>,
				 <SUN8I_V3S_PINMUX(PORT_C, 2, FUNC_PC_SPI0)>,
				 <SUN8I_V3S_PINMUX(PORT_C, 3, FUNC_PC_SPI0)>;
		};

		uart0_pins: uart0-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_B, 8, FUNC_PB_UART0)>,
						<SUN8I_V3S_PINMUX(PORT_B, 9, FUNC_PB_UART0)>;
			drive-strength = <3>;
			allwinner,pull = "pull_up";
		};

		mmc0_pins: mmc0-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_F, 0, FUNC_PF_SDC0)>,
				 <SUN8I_V3S_PINMUX(PORT_F, 1, FUNC_PF_SDC0)>,
				 <SUN8I_V3S_PINMUX(PORT_F, 2, FUNC_PF_SDC0)>,
				 <SUN8I_V3S_PINMUX(PORT_F, 3, FUNC_PF_SDC0)>,
				 <SUN8I_V3S_PINMUX(PORT_F, 4, FUNC_PF_SDC0)>,
				 <SUN8I_V3S_PINMUX(PORT_F, 5, FUNC_PF_SDC0)>;
			drive-strength = <3>;
			allwinner,pull = "pull_up";
		};

		lcd_rgb_pins: lcd-rgb-pins {
			pinmux = <SUN8I_V3S_PINMUX(PORT_E,  0, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  1, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  2, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  3, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  4, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  5, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  6, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  7, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  8, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E,  9, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 10, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 11, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 12, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 13, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 14, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 15, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 16, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 17, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 18, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 19, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 23, FUNC_LCD)>,
				 <SUN8I_V3S_PINMUX(PORT_E, 24, FUNC_LCD)>;
			drive-strength = <3>;
		};
	};
};

&gpiob {
	status = "okay";
};

&gpioe {
	status = "okay";
};

&gpiof {
	status = "okay";
};

&gpiog {
	status = "okay";
};

&spi0 {
	pinctrl-0 = <&spi0_pins>;
	pinctrl-names = "default";
	clock-source = <&osc24M>;
	status = "okay";
};

&i2c0 {
	pinctrl-0 = <&i2c0_pins>;
	pinctrl-names = "default";
	status = "okay";
	ns2009: ns2009@24 {
		compatible = "nsiway,ns2009";
		reg = <0x48>;
		status = "okay";
		screen-width = <800>;
		screen-height = <600>;
		inverted-y;		/* CH4 vertical axis: raw top=large, bottom=small */
		touch-threshold = <200>;
		poll-period-ms = <15>;
		release-timeout-ms = <100>;
		/*
		 * Calibration from touch data analysis:
		 *   X (CH5 horizontal): left~250  right~3950  (working well)
		 *   Y (CH4 vertical):   top~3750  bottom~280
		 *   Adjusted min-y/max-y to reduce center Y offset
		 */
		min-x = <100>;
		max-x = <4000>;
		min-y = <0>;
		max-y = <3600>;
	};
};

&usbphy {
	dr-mode = "otg";
	usb0_id_det-gpios = <&gpiof 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
	status = "okay";
};

zephyr_udc0:&usbotg {
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
		label = "USB CDC ACM";
		tx-fifo-size = <4096>;
		rx-fifo-size = <4096>;
	};
};

&mmc0 {
	pinctrl-0 = <&mmc0_pins>;
	pinctrl-names = "default";
	frequency = <DT_FREQ_M(100)>;
	status = "okay";
};

&usbphy {
	status = "okay";
};

&emac {
	allwinner,leds-active-low;
	status = "okay";
};

&mdio {
	status = "okay";
};

&crypto {
	status = "okay";
};

&rng {
	status = "okay";
};

&pwm {
	pinctrl-0 = <&pwm_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&rtc {
	status = "okay";
};

&display_clocks {
	status = "okay";
};

&mixer0 {
	status = "okay";
	width = <800>;
	height = <600>;
	pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
};

&tcon0 {
	status = "okay";
	pinctrl-0 = <&lcd_rgb_pins>;
	pinctrl-names = "default";
	backlight = <&pwm 0 1000>;
	display-timings {
		compatible = "zephyr,panel-timing";
		pixelclk-active = <0>;
		hsync-active = <0>;
		vsync-active = <0>;
		de-active = <1>;
		hsync-len = <128>;
		hback-porch = <88>;
		hfront-porch = <40>;
		vsync-len = <4>;
		vback-porch = <23>;
		vfront-porch = <1>;
		clock-frequency = <40000000>;
	};
};

&codec {
	status = "okay";
};

&codec_analog {
	status = "okay";
};
